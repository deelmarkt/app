# DeelMarkt — Environment Variables
# Copy to .env and fill in values from your Supabase dashboard.
# NEVER commit .env — only .env.example is tracked.

# Cloudinary
CLOUDINARY_URL=cloudinary://your-api-key:your-api-secret@your-cloud-name  # pragma: allowlist secret

# SonarCloud
SONAR_TOKEN=your-sonar-token

# Mollie
MOLLIE_PROFILE_ID=pfl_xxx
MOLLIE_TEST_API_KEY=test_xxx
MOLLIE_OAUTH_TOKEN=access_xxx

# Twilio (SMS OTP — referenced in supabase/config.toml)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_MESSAGE_SERVICE_SID=MGxxx
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Supabase
SUPABASE_PROJECT_NAME=deelmarkt-app
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_ANON_PUBLIC=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_SECRET=eyJ...your-service-role-key

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# PagerDuty
PAGERDUTY_ROUTING_KEY=your-routing-key
PAGERDUTY_ROUTING_URL=https://events.eu.pagerduty.com/v2/enqueue

# Unleash — Feature Flags (self-hosted on Railway/Render)
UNLEASH_URL=https://your-unleash-instance/api/frontend
UNLEASH_CLIENT_KEY=your-frontend-client-key
